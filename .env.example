# Maximus.ai Configuration

# Ollama Settings
OLLAMA_URL=http://localhost:11434
MODEL=qwen2.5-coder:7b

# Agent Limits
MAX_MODEL_CALLS=5000
MAX_CONCURRENT_TOOLS=5
CONTEXT_WINDOW=128000
COMPACTION_THRESHOLD=0.7

# Security
TRUST_LEVEL=basic  # untrusted, basic, verified, privileged
PERMISSION_MODE=auto  # auto, accept-all, manual

# Paths
WORKDIR=.
LOG_LEVEL=INFO

# Optional: OpenAI (not required for 100% free)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4
