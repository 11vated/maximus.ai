FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY pyproject.toml .
RUN pip install hatchling && pip install -e .

# Copy source
COPY src/ /app/src/
COPY maximus/ /app/maximus/

# Expose port
EXPOSE 8000

# Run the API server
CMD ["uvicorn", "maximus.api.routes:app", "--host", "0.0.0.0", "--port", "8000"]
